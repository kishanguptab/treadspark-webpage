# Database (Vercel Postgres / Neon)
DATABASE_URL=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@your-domain.com

# Interest report recipient
INTEREST_RECIPIENT_EMAIL=you@your-domain.com

# Vercel Cron authentication (random secret; Vercel sends as Bearer token)
CRON_SECRET=

# Public site URL — set after adding a custom domain, or leave unset to use *.vercel.app
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
